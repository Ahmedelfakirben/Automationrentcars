# ============================================================
# 2S1M AUTO-PUBLISHER - Variables de Entorno
# ============================================================
# Copia este archivo como .env y rellena los valores reales
# NUNCA subas el archivo .env al repositorio
# ============================================================

# Puerto del servidor (Coolify lo gestiona automáticamente)
PORT=3000

# API de Groq (generación de textos con IA)
# Obtener en: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Facebook Graph API
# Obtener en: https://developers.facebook.com/tools/explorer/
FACEBOOK_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
FACEBOOK_PAGE_ID=tu_page_id_aqui

# Photoroom API (eliminación y reemplazo de fondo con IA)
# Obtener en: https://app.photoroom.com/api-dashboard
PHOTOROOM_API_KEY=sk_pr_default_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (base de datos en la nube)
# Obtener en: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
